{
  "openapi": "3.0.3",
  "info": {
    "title": "根据ID查询账单接口",
    "description": "根据ID查询账单详情",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8090",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "账单管理",
      "description": "账单相关接口"
    }
  ],
  "paths": {
    "/api/bills/{id}": {
      "get": {
        "tags": ["账单管理"],
        "summary": "根据ID查询账单",
        "operationId": "getBillById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "账单ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultBillVO"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Result": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "响应码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "description": "响应数据"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "时间戳"
          }
        }
      },
      "ResultBillVO": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Result"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/BillVO"
              }
            }
          }
        ]
      },
      "BillVO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "账单ID"
          },
          "payee": {
            "type": "string",
            "description": "收款方"
          },
          "amount": {
            "type": "number",
            "format": "decimal",
            "description": "金额"
          },
          "transactionTime": {
            "type": "string",
            "format": "date-time",
            "description": "交易时间"
          },
          "paymentMethodId": {
            "type": "integer",
            "format": "int64",
            "description": "支付方式ID"
          },
          "paymentMethodName": {
            "type": "string",
            "description": "支付方式名称"
          },
          "transactionNo": {
            "type": "string",
            "description": "交易号"
          },
          "categoryId": {
            "type": "integer",
            "format": "int64",
            "description": "分类ID"
          },
          "categoryName": {
            "type": "string",
            "description": "分类名称"
          },
          "remark": {
            "type": "string",
            "description": "备注"
          },
          "createTime": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          }
        }
      }
    }
  }
}

