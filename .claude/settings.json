{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-related-tests.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(mvn -f backend/pom.xml -Dtest=*)",
      "Bash(mvn -Dtest=*)",
      "Bash(bash .claude/hooks/*)"
    ]
  }
}
